API_VERSION="v1"
JWT_ACCESS_SECRET="cnweb"
JWT_REFRESH_SECRET="cnweb-refresh"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_DAYS=7

API_GATEWAY_URL=http://localhost:3000
AUTH_SERVICE_URL=http://localhost:3001
CATALOG_SERVICE_URL=http://localhost:3002
COMMERCE_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004

CORS_ALLOWED_ORIGINS=http://localhost:5173
CART_ITEM_LIMIT=100

# Service-specific .env files should still define PORT and DATABASE_URL.
# Example:
# PORT=3001
# DATABASE_URL="postgresql://postgres:password@localhost:5432/cnweb?schema=auth_service"
